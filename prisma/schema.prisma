generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Tree model for plant/tree catalog
model Tree {
    id          String    @id @default(uuid())
    name        String
    description String
    categoryId  String
    images      Image[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    // Relations
    category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// Category model for tree categories
model Category {
    id          String    @id @default(uuid())
    name        String
    description String
    imageId     String?   @unique
    trees       Tree[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    // Relations
    image       Image?    @relation(fields: [imageId], references: [id], onDelete: SetNull)
}

// Image model for storing tree and category images
model Image {
    id         String    @id @default(uuid())
    treeId     String?
    link       String
    createdAt  DateTime  @default(now())

    // Relations
    tree       Tree?     @relation(fields: [treeId], references: [id], onDelete: Cascade)
    category   Category?
}

